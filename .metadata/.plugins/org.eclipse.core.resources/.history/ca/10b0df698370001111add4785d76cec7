package lamdaFunction;

class Employe {
	private String name;
	private String company;
	private double salary;

	public Employe(String name, String company, double salary) {
		this.name = name;
		this.company = company;
		this.salary = salary;
	}

	public String getCompany() {
		return company;
	}

	@Override
	public String toString() {
		return name + " - " + salary;
	}
}
