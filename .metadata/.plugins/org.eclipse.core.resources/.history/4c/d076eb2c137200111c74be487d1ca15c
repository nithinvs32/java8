package practiesQuestions;

import java.util.*;
import java.util.stream.*;

public class EmployeeBySal {

	public static void main(String[] args) {

		List<Employee> emp = Arrays.asList(new Employee("John", "Wipro", 45000), new Employee("Ravi", "Infosys", 38000),
				new Employee("Anu", "TCS", 50000), new Employee("Priya", "Wipro", 65000),
				new Employee("Raj", "Infosys", 35000), new Employee("Kiran", "TCS", 30000),
				new Employee("Neha", "Wipro", 25000), new Employee("raj", "Infosys", 70000),
				new Employee("Neha", "Wipro", 25000), new Employee("ram", "Wipro", 40000),
				new Employee("Neha", "Wipro", 25000), new Employee("ramanji", "TCS", 34000),
				new Employee("Neha", "Wipro", 25000), new Employee("kishor", "Infosys", 63000),
				new Employee("Neha", "Wipro", 25000), new Employee("kamal", "Wipro", 250000),
				new Employee("Neha", "Wipro", 25000), new Employee("Manoj", "TCS", 62000),
				new Employee("Neha", "Wipro", 25000), new Employee("Amala", "Amazon", 33000));
		emp.forEach(n -> System.out.println(n.getName()));

		List<Double> wiproSalary = emp.stream().filter(e -> e.getCompany().equals("Wipro"))
				.map(Employee -> Employee.getSalary()).collect(Collectors.toList());

		System.out.println("Wipro Salaries : " + wiproSalary);

	}
}
